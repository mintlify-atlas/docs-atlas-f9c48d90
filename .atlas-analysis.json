  "keyFeatures": [
    "Event management with real-time registrations and waitlists",
    "Job listings and company profiles for student recruitment",
    "Student profile management with points system",
    "Admin dashboard (Bifrost) for content and event management",
    "Public-facing website (Midgard) for students and companies",
    "Real-time sync with Convex backend",
    "Authentication and authorization with Clerk",
    "Shared UI component library with shadcn/ui",
    "Monorepo architecture with Turborepo",
    "Email notifications with React Email"
  ],
